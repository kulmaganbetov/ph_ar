OPENAI_API_KEY=sk-...
JWT_SECRET=your-random-secret-here

# Preferred Upstash REST vars
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Also supported (Vercel-style aliases)
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# Optional URL forms (token and host can be parsed from here)
KV_URL=rediss://default:token@your-db.upstash.io:6379
REDIS_URL=rediss://default:token@your-db.upstash.io:6379
